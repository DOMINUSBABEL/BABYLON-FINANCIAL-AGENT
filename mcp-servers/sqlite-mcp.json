{
  "mcpServers": {
    "sqlite-ledger": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db", "db/ledger.sqlite"],
      "env": {
        "SQLITE_ReadOnly": "false",
        "SQLITE_SafeMode": "true",
        "SQLITE_MaxQueryTimeMs": "2000"
      }
    }
  }
}